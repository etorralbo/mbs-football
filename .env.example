# -----------------------------------------------------------------------
# Root environment file for docker-compose.
# Copy to .env for local development:  cp .env.example .env
# Never commit .env — it is listed in .gitignore.
# -----------------------------------------------------------------------

# Supabase project URL (https://<project-id>.supabase.co)
# Obtain from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=

# Supabase anonymous (public) key — safe to expose client-side.
# Used by the frontend to initialise the Supabase JS client.
SUPABASE_ANON_KEY=

# JWT audience claim — "authenticated" is the Supabase default.
SUPABASE_JWT_AUD=authenticated

# Frontend base URL — used by the backend to build invite links.
# Local: http://localhost:3000 | Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# OpenAI API key — required when AI_STUB=false and AI_ENABLED=true.
# Leave empty to use stub mode locally.
OPENAI_API_KEY=

# AI model to use for template generation.
AI_MODEL=gpt-4o-mini

# Feature flag: set false to disable AI endpoints entirely.
AI_ENABLED=true

# Stub mode: replace real OpenAI calls with deterministic fixtures.
# Recommended for local development (no API key needed).
AI_STUB=true

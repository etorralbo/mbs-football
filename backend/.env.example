# -----------------------------------------------------------------------
# Copy this file to .env for local development.
# Never commit .env — it is listed in .gitignore.
# In production (Render) set these as system environment variables.
# -----------------------------------------------------------------------

# Database connection string
# Local example:  postgresql+psycopg://app:app@localhost:5432/app
# Render example: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=

# Supabase project URL (https://<ref>.supabase.co)
SUPABASE_URL=

# JWT audience claim — default is fine for Supabase projects
SUPABASE_JWT_AUD=authenticated

# Derived automatically from SUPABASE_URL; only set to override
# SUPABASE_JWT_ISSUER=
# SUPABASE_JWKS_URL=

# Frontend base URL — used to build invite join links
FRONTEND_URL=http://localhost:3000

# AI integration
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ENABLED=true
# Set true to skip real OpenAI calls (use deterministic stubs)
AI_STUB=true

# Environment: local | test | production
ENV=local

# CORS — at least one of the two must be set in production.
# Exact origins (comma-separated) — use for stable production URLs:
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app
# Regex for dynamic origins — use for Vercel preview deployments:
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app$
